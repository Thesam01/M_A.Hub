        .chat-input:focus {
            border-color: var(--accent-gold);
            box-shadow: 0 0 0 3px rgba(201, 168, 76, 0.1);
        }

        .chat-send {
            background: linear-gradient(135deg, var(--accent-gold) 0%, #d4af57 100%);
            color: white;
            border: none;
            padding: 0.75rem 1.5rem;
            font-weight: 700;
            font-size: 0.8rem;
            cursor: pointer;
            transition: all 0.2s;
            border-radius: 6px;
            text-transform: uppercase;
            letter-spacing: 0.05em;
