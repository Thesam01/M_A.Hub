                        <div class="co-price">
                            <div class="co-price-val ${c.up ? 'up' : 'dn'}">${c.price}</div>
                            <div class="co-price-chg ${c.up ? 'up' : 'dn'}">${c.chg || '—'}</div>
                        </div>
                    </div>
                    <div class="co-badges">
                        ${c.badges.map(b => `<span class="badge badge-dim">${b}</span>`).join('')}
                    </div>
                    <div class="co-desc">${c.desc}</div>
                    <div class="co-cta">${c.cta || 'View M&A Profile'}</div>
                </div>`;
            });
            document.getElementById('companyGrid').innerHTML = html;
        }

        function loadRegions() {
            let regionsHtml = '';
            REGIONS_DATA.forEach(r => {
                regionsHtml += `<div class="region-card">
                    <span class="region-flag">${r.flag}</span>
                    <div class="region-name">${r.name}</div>
                    <div class="region-count">${r.count}</div>
                    <div>
                        <div class="region-vol">${r.vol}</div>
                        <div class="region-vol-label">YTD Deal Volume</div>
                    </div>
                    <p style="font-size: 0.8rem; color: var(--text-secondary); line-height: 1.7; margin-top: 1rem;">${r.desc}</p>
                </div>`;
            });
            document.getElementById('regionsGrid').innerHTML = regionsHtml;

            let alertsHtml = '';
            ALERTS_DATA.forEach(a => {
                alertsHtml += `<div class="alert-item">
                    <span class="alert-tag">${a.tag}</span>
                    <span class="alert-text">${a.text}</span>
                </div>`;
            });
            document.getElementById('alertsContainer').innerHTML = alertsHtml;

            let signalsHtml = '';
            SIGNAL_CARDS_DATA.forEach(s => {
                const colorMap = { gold: 'rgba(201, 168, 76, 0.2)', red: 'rgba(207, 68, 68, 0.2)', blue: 'rgba(74, 143, 193, 0.2)' };
                const textColorMap = { gold: 'var(--accent-gold)', red: 'var(--accent-red)', blue: 'var(--accent-blue)' };
                signalsHtml += `<div class="signal-card">
                    <div class="signal-badge" style="background: ${colorMap[s.color]}; color: ${textColorMap[s.color]};">${s.badge}</div>
                    <div class="signal-title">${s.title}</div>
                    <p class="signal-body">${s.body}</p>
                </div>`;
            });
            document.getElementById('signalsGrid').innerHTML = signalsHtml;
        }

        function loadAnalysis() {
            const initialMsg = "Welcome to M&A Hub Intelligence. I'm your AI-powered deal analyst. Ask me about current deals, sector trends, regulatory risks, or valuation multiples across any market.";
            let html = `<div class="msg msg-ai">
                <div class="msg-label">⬡ M&A AI</div>
                <div>${initialMsg}</div>
            </div>`;
            document.getElementById('chatMessages').innerHTML = html;

            const quickQueries = [
                "What are the largest pending deals right now?",
                "Which sectors have the highest M&A activity?",
                "What is the regulatory risk for tech acquisitions?",
                "Show me recent healthcare M&A trends",
                "What PE buyout activity is expected in 2025?",
            ];

            let quickHtml = '';
            quickQueries.forEach(q => {
                quickHtml += `<button class="quick-btn" onclick="sendMessage('${q.replace(/'/g, "\\'")}')">${q}</button>`;
            });
            document.getElementById('quickBtns').innerHTML = quickHtml;
        }

        function sendMessage(text) {
            const input = document.getElementById('chatInput');
            const msg = text || input.value.trim();
            if (!msg) return;

            const messagesDiv = document.getElementById('chatMessages');
            const userMsg = document.createElement('div');
            userMsg.className = 'msg msg-user';
            userMsg.innerHTML = `<div class="msg-label">▶ YOU</div><div>${msg}</div>`;
            messagesDiv.appendChild(userMsg);

            input.value = '';
            messagesDiv.scrollTop = messagesDiv.scrollHeight;

            setTimeout(() => {
                const response = AI_RESPONSES[aiResponseIndex % AI_RESPONSES.length];
                aiResponseIndex++;

                const aiMsg = document.createElement('div');
                aiMsg.className = 'msg msg-ai';
                aiMsg.innerHTML = `<div class="msg-label">⬡ M&A AI</div><div>${response}</div>`;
                messagesDiv.appendChild(aiMsg);
                messagesDiv.scrollTop = messagesDiv.scrollHeight;
            }, 1400);
        }

        function loadIntelligence() {
            const kpiData = [
                { label: 'Global Deal Volume YTD', val: '$847B', chg: '+14.2%', up: true },
                { label: 'Avg. Premium Paid', val: '32.4%', chg: '+2.1pp', up: true },
                { label: 'Avg. Close Time', val: '8.4 mo', chg: '+0.6 mo', up: false },
                { label: 'Failed Deals YTD', val: '14', chg: '-3 vs prior yr', up: true },
                { label: 'PE Dry Powder', val: '$3.9T', chg: '+8.2%', up: true },
                { label: 'Cross-border Deals', val: '38%', chg: '+4pp', up: true },
            ];

            let html = '';
            kpiData.forEach(k => {
                html += `<div class="card">
                    <div style="font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-secondary); margin-bottom: 0.5rem; font-weight: 700;">${k.label}</div>
                    <div style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.6rem; font-weight: 800; color: var(--accent-gold); letter-spacing: -0.02em;">${k.val}</div>
                    <div style="font-size: 0.75rem; color: ${k.up ? 'var(--accent-green)' : 'var(--accent-red)'}; margin-top: 0.5rem; font-weight: 600;">${k.chg}</div>
                </div>`;
            });
            document.getElementById('kpiGrid').innerHTML = html;
        }

        function loadMakeDeals() {
            const sectors = [
                {'id': 'tech', 'name': 'Technology', 'icon': '💻', 'desc': 'Software, hardware, semiconductors, AI, cloud & cybersecurity', 'dealVol': '$1.2T', 'deals': '420'},
                {'id': 'healthcare', 'name': 'Healthcare', 'icon': '🏥', 'desc': 'Pharma, biotech, med-tech, diagnostics & health services', 'dealVol': '$380B', 'deals': '218'},
                {'id': 'energy', 'name': 'Energy', 'icon': '⚡', 'desc': 'Oil & gas, renewables, utilities, mining & battery metals', 'dealVol': '$540B', 'deals': '184'},
                {'id': 'finance', 'name': 'Finance', 'icon': '🏦', 'desc': 'Banking, insurance, asset management, fintech & payments', 'dealVol': '$620B', 'deals': '312'},
                {'id': 'consumer', 'name': 'Consumer', 'icon': '🛍️', 'desc': 'Retail, food & beverage, luxury, e-commerce & FMCG', 'dealVol': '$290B', 'deals': '256'},
            ];

            let html = '';
            sectors.forEach(s => {
                html += `<div class="md-sector-card" onclick="alert('Sector: ${s.name}')">
                    <div class="md-sector-icon">${s.icon}</div>
                    <div class="md-sector-title">${s.name}</div>
                    <div class="md-sector-sub">${s.desc}</div>
                    <div class="md-sector-stats">
                        <div>
                            <div class="md-sector-stat-num" style="color: var(--accent-gold);">${s.dealVol}</div>
                            <div class="md-sector-stat-lbl">Deal Vol.</div>
                        </div>
                        <div>
                            <div class="md-sector-stat-num" style="color: var(--text-primary);">${s.deals}</div>
                            <div class="md-sector-stat-lbl">Active Deals</div>
                        </div>
                    </div>
                </div>`;
            });
            document.getElementById('mdContent').innerHTML = html;
        }
    </script>
