            border-radius: 8px;
            max-width: 80%;
            color: white;
        }

        .chat-input-row {
            display: flex;
            gap: 0.75rem;
            padding: 1.25rem;
            border-top: 1px solid var(--border-color);
            background: var(--bg-tertiary);
        }

        .chat-input {
            flex: 1;
            background: var(--bg-secondary);
            border: 1px solid var(--border-color);
            color: var(--text-primary);
            padding: 0.75rem 1rem;
            font-family: 'Poppins', sans-serif;
            font-size: 0.85rem;
            outline: none;
            border-radius: 6px;
            transition: all 0.2s;
