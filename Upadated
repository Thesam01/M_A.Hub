                grid-template-columns: 1fr;
            }

            .company-grid {
                grid-template-columns: 1fr;
            }

            .md-sector-grid {
                grid-template-columns: 1fr;
            }

            .section-content {
                padding: 1.5rem;
            }
        }
    </style>
</head>
