        .msg {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
            font-size: 0.85rem;
            line-height: 1.6;
        }

        .msg-ai {
            align-items: flex-start;
        }

        .msg-user {
            align-items: flex-end;
        }

        .msg-label {
            font-size: 0.7rem;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            font-weight: 700;
            color: var(--text-secondary);
