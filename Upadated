        function filterDeals() {
            const search = document.getElementById('dealSearch').value.toLowerCase();
            const sector = document.getElementById('sectorFilter').value;
            const region = document.getElementById('regionFilter').value;

            const filtered = allDeals.filter(d => {
                if (search && !d.acquirer.toLowerCase().includes(search) &&
                    !d.target.toLowerCase().includes(search) &&
                    !d.sector.toLowerCase().includes(search)) return false;
                if (sector && d.sector !== sector) return false;
                if (region && d.region !== region) return false;
                return true;
            });

            renderDeals(filtered);
        }

