        .msg-ai .msg-label {
            color: var(--accent-gold);
        }

        .msg-ai > div:not(.msg-label) {
            background: var(--bg-tertiary);
            padding: 1rem;
            border-radius: 8px;
            max-width: 80%;
            color: var(--text-secondary);
        }

